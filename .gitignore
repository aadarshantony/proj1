# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/html

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# prisma
prisma/migrations/*.sql

# storybook
storybook-static/

# IDE
.idea/
.vscode/

# Submodule node_modules
packages/*/node_modules

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Chrome Extension build outputs
src/extensions/chrome/dist/
src/extensions/chrome/release/

.claude/
.claude_backup/

# Local preview pages (not committed)
src/app/(local-preview)/

(showcase)/
claude-backup.zip
.dev-pipeline/
