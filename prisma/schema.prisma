// 도메인 SaaS 스캔 히스토리 - 검토 대기 앱 리스트용
model SaaSDomainScanHistory {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  domain         String       // 메인 도메인 (google.com)
  isSaaS         Boolean      @map("is_saas")
  serviceName    String?      @map("service_name")
  category       String?
  confidence     Float?
  catalogId      String?      @map("catalog_id")
  website        String?
  reasoning      String?
  scannedAt      DateTime     @default(now()) @map("scanned_at")

  // 악성 URL 검사 관련 필드
  isMalicious           Boolean   @default(false) @map("is_malicious")
  threatType            String?   @map("threat_type") // MALWARE, SOCIAL_ENGINEERING, UNWANTED_SOFTWARE, POTENTIALLY_HARMFUL_APPLICATION
  safeBrowsingCheckedAt DateTime? @map("safe_browsing_checked_at")
  reviewStatus          String    @default("pending") @map("review_status") // pending, registered, blocked

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  catalog      SaaSCatalog? @relation(fields: [catalogId], references: [id])

  @@unique([organizationId, domain])
  @@index([organizationId])
  @@index([isSaaS])
  @@index([isMalicious])
  @@index([reviewStatus])
  @@index([scannedAt])
  @@map("saas_domain_scan_history")
}

