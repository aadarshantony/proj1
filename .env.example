# saaslens - 환경 변수 예시
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요

# ===========================================
# 데이터베이스 (Supabase PostgreSQL)
# ===========================================
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ===========================================
# NextAuth.js v5 설정
# ===========================================
# openssl rand -base64 32 로 생성
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# Google OAuth (NextAuth Provider)
# ===========================================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===========================================
# Google Workspace Admin SDK (SSO 연동)
# ===========================================
GOOGLE_ADMIN_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_ADMIN_SUBJECT="admin@yourdomain.com"

# ===========================================
# Redis (Upstash)
# ===========================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="SaaS 관리 플랫폼"

# ===========================================
# File Storage (Cloudflare R2)
# ===========================================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="smp-files"

# ===========================================
# Vercel Cron 인증
# ===========================================
# openssl rand -base64 32 로 생성
CRON_SECRET="your-cron-secret-here"

# ===========================================
# 앱 설정
# ===========================================
NODE_ENV="development"
# Refine gradual enable feature flag
ENABLE_REFINE="false"

# ===========================================
# OpenAI API (SaaS 분류 LLM)
# ===========================================
OPENAI_API_KEY="your-openai-api-key-here"
# 선택사항: 기본값은 gpt-4o-mini
OPENAI_FAST_MODEL="gpt-4o-mini"

# ===========================================
# V2 기능 토글
# ===========================================
# V2 기능 활성화 여부 (Tasks/Kanban 등)
# true로 설정 시 V2 기능 접근 가능
ENABLE_V2_FEATURES="false"

FLEETDM_API_URL="your-fleetdm-api-url"
FLEETDM_API_TOKEN="your-fleetdm-api-token"